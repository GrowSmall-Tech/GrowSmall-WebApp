# Copy to `.env.local` and fill in values. Never commit real secrets.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin login (server-side). Used only by /api/admin/login and session signing.
# Preferred key is ADMIN_EMAIL. ADMIN_ID is also accepted for compatibility.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Required for admin CRUD (server actions). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
